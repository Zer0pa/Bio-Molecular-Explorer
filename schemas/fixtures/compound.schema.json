{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zer0pa.ai/schemas/fixtures/compound.schema.json",
  "title": "Zer0pa Health Cardiac Compound Fixture",
  "description": "Research use only. Not for diagnosis, treatment, cure claims, prescribing, clinical deployment, regulatory compliance, or drug-safety certification.",
  "type": "object",
  "required": [
    "research_boundary",
    "name",
    "inchikey",
    "canonical_smiles",
    "drug_class_research_label",
    "cardiac_research_role",
    "channel_panel_canned",
    "expected_packet_verdict",
    "expected_morphology_signal",
    "stub_provenance_note"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "research_boundary": {
      "type": "string",
      "const": "Research use only. Not for diagnosis, treatment, cure claims, prescribing, clinical deployment, regulatory compliance, or drug-safety certification."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "inchikey": {
      "type": "string",
      "pattern": "^[A-Z]{14}-[A-Z]{10}-[A-Z]$"
    },
    "canonical_smiles": {
      "type": "string",
      "minLength": 1
    },
    "drug_class_research_label": {
      "type": "string",
      "minLength": 1
    },
    "cardiac_research_role": {
      "type": "string",
      "minLength": 1
    },
    "channel_panel_canned": {
      "type": "object",
      "required": ["KCNH2_hERG_IKr", "SCN5A_Nav1_5_INa_INaL", "KCNQ1_Kv7_1_IKs", "CACNA1C_CaV1_2_ICaL"],
      "additionalProperties": false,
      "properties": {
        "KCNH2_hERG_IKr": { "$ref": "#/$defs/panel_entry" },
        "SCN5A_Nav1_5_INa_INaL": { "$ref": "#/$defs/panel_entry" },
        "KCNQ1_Kv7_1_IKs": { "$ref": "#/$defs/panel_entry" },
        "CACNA1C_CaV1_2_ICaL": { "$ref": "#/$defs/panel_entry" }
      }
    },
    "expected_packet_verdict": {
      "type": "string",
      "enum": ["pass", "fail", "inconclusive", "blocked"]
    },
    "expected_morphology_signal": {
      "type": "string",
      "minLength": 1
    },
    "stub_provenance_note": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "panel_entry": {
      "type": "object",
      "required": ["ic50_uM", "block_fraction_at_cmax_unbound", "method", "confidence"],
      "additionalProperties": false,
      "properties": {
        "ic50_uM": {
          "oneOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        },
        "block_fraction_at_cmax_unbound": {
          "oneOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "explicit_absence": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
